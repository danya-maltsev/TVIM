<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IVORY FLOWERS — Букеты, созданные с заботой и вкусом</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --ivory: #FAF7F2;
  --cream: #F3EDE4;
  --warm-white: #FFFDF9;
  --olive: #4A4A42;
  --olive-light: #6A6A62;
  --charcoal: #1A1A1A;
  --text-primary: #1A1A1A;
  --text-secondary: #555555;
  --text-muted: #888888;
  --border-light: rgba(26, 26, 24, 0.08);
  --border-medium: rgba(26, 26, 24, 0.15);

  --font-display: 'Cormorant Garamond', Georgia, serif;
  --font-body: 'Manrope', sans-serif;

  --space-xs: 0.5rem;
  --space-sm: 1rem;
  --space-md: 1.5rem;
  --space-lg: 2.5rem;
  --space-xl: 4rem;
  --space-2xl: 6rem;
  --space-3xl: 8rem;

  --container: 1320px;
  --side-pad: 2.5rem;
}

/* ================================================================
   FIX #1 — TILDA FONT COLOR OVERRIDES
   Forces white text everywhere Tilda injects its default orange/
   accent color. Covers text blocks, links, buttons, cards, menu
   items, hover/visited states — everything Tilda might paint orange.
   ================================================================ */

/* --- All text elements --- */
.t-text,
.t-title,
.t-descr,
.t-name,
.t-heading,
.t-subtitle,
.t-uptitle,
.t-card__title,
.t-card__descr,
.t-store__card__title,
.t-store__card__price,
.t-store__card__btn,
.t-store__card__descr,
.t-btn__text,
[class*="tn-atom"],
[class*="t-card__"],
[class*="t-store__card__"],
.t396__elem .tn-atom,
.t-col .tn-atom,
.t-section .tn-atom,
.t-container .tn-atom,
.t-col__content .tn-atom,
.t396 .tn-atom,
.t-rec .tn-atom {
  color: #FFFFFF !important;
}

/* --- All links within Tilda containers --- */
.t-body a,
.t-body a:link,
.t-body a:visited,
.t-body a:hover,
.t-body a:active,
.t-menu__link-item,
.t-menu__link-item a,
.t-footer__link,
.t-footer a,
[class*="tn-atom"] a,
[class*="tn-atom"] a:link,
[class*="tn-atom"] a:visited,
[class*="tn-atom"] a:hover,
.tn-atom a,
.tn-atom a:link,
.tn-atom a:visited,
.tn-atom a:hover,
.t-sociallinks__item a,
.t-rec a,
.t-rec a:link,
.t-rec a:visited,
.t-rec a:hover,
.t-col a,
.t-col a:link,
.t-col a:visited,
.t-col a:hover,
.t-container a,
.t-container a:link,
.t-container a:visited,
.t-container a:hover,
.t-section a,
.t-section a:link,
.t-section a:visited,
.t-section a:hover,
.t396 a,
.t396 a:link,
.t396 a:visited,
.t396 a:hover {
  color: #FFFFFF !important;
}

/* --- Tilda buttons --- */
.t-submit,
.t-btn,
.t-btn a,
.t-btn__text,
.t-form__submit button,
.t-body [class*="t-btn"],
.t-store__card__btn a,
.t-store__card__btn {
  color: #FFFFFF !important;
}

/* --- Override inline styles Tilda injects via style="" attribute --- */
.t-body [style*="color"],
.t-body a[style*="color"],
.t-rec [style*="color"],
.t-rec a[style*="color"] {
  color: #FFFFFF !important;
}

/* --- Font family override --- */
.t-body,
.t-body .t-text,
.t-body .t-title,
.t-body .t-descr,
.t-body .t-name,
.t-body .t-heading,
.t-body .t-subtitle,
.t-body .tn-atom,
.t-body a {
  font-family: var(--font-body) !important;
}

/* ================================================================
   SAFEGUARD: Re-assert dark colors on our own light-background
   components that Tilda's white !important overrides may break.
   These must come AFTER the Tilda block to win the cascade.
   ================================================================ */
.site-header a,
.site-header a:link,
.site-header a:visited,
.hero-content a:not(.btn-primary),
.hero-content a:link:not(.btn-primary),
.hero-content a:visited:not(.btn-primary),
.hero-content p,
.hero-content h1,
.hero-content .hero-label,
.hero-content .hero-desc,
.catalog-teaser a,
.catalog-teaser a:link,
.catalog-teaser a:visited,
.catalog-teaser p,
.catalog-teaser h2,
.catalog-teaser span,
.about-section a,
.about-section p,
.about-section h2,
.process-section a,
.process-section p,
.process-section h2,
.process-section h3,
.hero-product-card,
.hero-product-card a,
.hero-product-card .card-name,
.hero-product-card .card-price,
.hero-product-card .card-link {
  color: #1A1A1A !important;
}

/* btn-primary must stay white on dark background */
.hero-content .btn-primary,
.hero-content .btn-primary:link,
.hero-content .btn-primary:visited,
.hero-content .btn-primary:hover,
.hero-content .btn-primary:active,
.hero-content .btn-primary .arrow {
  color: #FFFFFF !important;
}

/* Muted text on light backgrounds */
.hero-label,
.hero-desc,
.catalog-header-right .section-desc,
.about-right .about-text,
.about-left .about-subtitle,
.process-header .section-subtitle,
.step-desc,
.catalog-header-left .section-label,
.about-left .section-label,
.process-header .section-label {
  color: #555555 !important;
}
/* Olive accent stays for italic title */
.hero-title em {
  color: var(--olive) !important;
}

html {
  scroll-behavior: smooth;
  font-size: 16px;
}

body {
  font-family: var(--font-body);
  background-color: var(--ivory);
  color: var(--text-primary);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
}

.container {
  max-width: var(--container);
  margin: 0 auto;
  padding: 0 var(--side-pad);
}

a { color: inherit; text-decoration: none; }
img { display: block; max-width: 100%; }

/* ========== PRELOADER ========== */
.preloader {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: var(--ivory);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.6s ease, visibility 0.6s ease;
}
.preloader.hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}
.preloader-logo {
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 400;
  letter-spacing: 0.15em;
  color: var(--text-primary);
  opacity: 0;
  animation: preloaderFade 1.2s ease forwards;
}
@keyframes preloaderFade {
  0% { opacity: 0; transform: translateY(8px); }
  40% { opacity: 1; transform: translateY(0); }
  80% { opacity: 1; }
  100% { opacity: 0.3; }
}

/* ================================================================
   FIX #2 — HEADER GRID ALIGNMENT
   ================================================================ */
.header-wrap {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(250, 247, 242, 0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  transition: background 0.4s ease, backdrop-filter 0.4s ease;
}
.header-wrap.scrolled {
  background: rgba(250, 247, 242, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border-light);
}

.site-header {
  max-width: var(--container);
  margin: 0 auto;
  padding: 1.25rem var(--side-pad);
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: padding 0.4s ease;
}
.header-wrap.scrolled .site-header {
  padding-top: 0.8rem;
  padding-bottom: 0.8rem;
}

.header-logo {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.header-logo .logo-mark {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--olive);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--ivory);
  font-family: var(--font-display);
  font-size: 0.85rem;
  font-weight: 500;
  letter-spacing: 0.05em;
}
.header-logo .logo-text {
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.header-nav {
  display: flex;
  align-items: center;
  gap: 2.5rem;
}
.header-nav a,
.header-nav a:link,
.header-nav a:visited,
.header-nav a:hover,
.header-nav a:active {
  font-family: var(--font-body) !important;
  font-size: 0.8rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #1A1A1A !important;
  transition: color 0.3s ease;
  position: relative;
}
.header-nav a::after {
  content: '';
  position: absolute;
  bottom: -3px;
  left: 0;
  width: 0;
  height: 1px;
  background: var(--text-primary);
  transition: width 0.3s ease;
}
.header-nav a:hover { color: var(--text-primary); }
.header-nav a:hover::after { width: 100%; }

/* ================================================================
   FIX #4 — VK & TELEGRAM ICONS
   ================================================================ */
.header-socials {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.header-socials a,
.header-socials a:link,
.header-socials a:visited,
.header-socials a:hover,
.header-socials a:active {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 1px solid rgba(26, 26, 26, 0.3) !important;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1A1A1A !important;
  transition: all 0.3s ease;
}
.header-socials a:hover {
  border-color: #1A1A1A !important;
  color: #1A1A1A !important;
  background: rgba(26, 26, 26, 0.06);
}
.header-socials a svg {
  width: 16px;
  height: 16px;
}

/* ================================================================
   FIX #3a — HERO HEIGHT = 100vh
   ================================================================ */
.hero {
  height: 100vh;
  max-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  position: relative;
  overflow: hidden;
}

.hero-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 5rem 3rem 3rem calc(max(var(--side-pad), (100vw - var(--container)) / 2 + var(--side-pad)));
}

.hero-label {
  font-family: var(--font-body);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: var(--space-md);
  opacity: 0;
  animation: fadeUp 0.8s ease 0.8s forwards;
}

.hero-title {
  font-family: var(--font-display);
  font-size: clamp(2.8rem, 4.5vw, 4.5rem);
  font-weight: 300;
  line-height: 1.0;
  letter-spacing: -0.02em;
  margin-bottom: var(--space-md);
  opacity: 0;
  animation: fadeUp 0.8s ease 1s forwards;
}
.hero-title em {
  font-style: italic;
  font-weight: 300;
  color: var(--olive);
}

.hero-desc {
  font-family: var(--font-body);
  font-size: 0.9rem;
  line-height: 1.75;
  color: var(--text-secondary);
  max-width: 400px;
  margin-bottom: var(--space-lg);
  opacity: 0;
  animation: fadeUp 0.8s ease 1.2s forwards;
}

.hero-actions {
  display: flex;
  align-items: center;
  gap: 2rem;
  opacity: 0;
  animation: fadeUp 0.8s ease 1.4s forwards;
}

.btn-primary,
.btn-primary:link,
.btn-primary:visited,
.btn-primary:hover,
.btn-primary:active {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  font-family: var(--font-body) !important;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 1rem 2.25rem;
  background: var(--charcoal);
  color: #FFFFFF !important;
  border: none;
  border-radius: 100px;
  cursor: pointer;
  transition: all 0.3s ease;
}
.btn-primary:hover {
  background: var(--olive);
  transform: translateY(-1px);
}
.btn-primary .arrow { transition: transform 0.3s ease; color: #FFFFFF !important; }
.btn-primary:hover .arrow { transform: translateX(3px); }

.btn-ghost,
.btn-ghost:link,
.btn-ghost:visited,
.btn-ghost:active {
  font-family: var(--font-body) !important;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #1A1A1A !important;
  border-bottom: 1.5px solid #1A1A1A !important;
  padding-bottom: 3px;
  transition: all 0.3s ease;
  cursor: pointer;
}
.btn-ghost:hover {
  color: #4A4A42 !important;
  border-color: #4A4A42 !important;
}

.hero-visual {
  position: relative;
  overflow: hidden;
}
.hero-visual .hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0;
  animation: heroImgReveal 1.2s ease 0.5s forwards;
}

/* ================================================================
   FIX #3b — PRODUCT CARD
   ================================================================ */
.hero-product-card {
  position: absolute;
  bottom: 2.5rem;
  left: 2.5rem;
  background: var(--warm-white);
  padding: 1.25rem 1.5rem;
  display: flex;
  align-items: center;
  gap: 1.25rem;
  border-radius: 4px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
  opacity: 0;
  animation: fadeUp 0.8s ease 1.6s forwards;
  min-width: 260px;
}
.hero-product-card .card-img {
  width: 72px;
  height: 72px;
  border-radius: 3px;
  object-fit: cover;
  background: var(--cream);
}
.hero-product-card .card-info { flex: 1; }
.hero-product-card .card-name {
  font-family: var(--font-display);
  font-size: 1.05rem;
  font-weight: 500;
  margin-bottom: 0.1rem;
}
.hero-product-card .card-price {
  font-family: var(--font-body);
  font-size: 0.85rem;
  font-weight: 600;
  color: #333333;
  margin-bottom: 0.4rem;
}
.hero-product-card .card-link,
.hero-product-card .card-link:link,
.hero-product-card .card-link:visited {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #1A1A1A !important;
  transition: color 0.3s ease;
}
.hero-product-card .card-link:hover { color: #555555 !important; }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes heroImgReveal {
  from { opacity: 0; transform: scale(1.05); }
  to { opacity: 1; transform: scale(1); }
}

/* ========== MARQUEE DIVIDER ========== */
.marquee-section {
  padding: var(--space-lg) 0;
  border-top: 1px solid var(--border-light);
  border-bottom: 1px solid var(--border-light);
  overflow: hidden;
}
.marquee-track {
  display: flex;
  animation: marqueeScroll 30s linear infinite;
  width: max-content;
}
.marquee-item {
  display: flex;
  align-items: center;
  gap: 2rem;
  padding: 0 2rem;
  white-space: nowrap;
}
.marquee-item span {
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-weight: 400;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-muted);
}
.marquee-item .dot {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: var(--text-muted);
  flex-shrink: 0;
}
@keyframes marqueeScroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ========== CATALOG TEASER ========== */
.catalog-teaser { padding: var(--space-3xl) 0; }
.catalog-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: var(--space-xl);
}
.catalog-header-left .section-label {
  font-family: var(--font-body);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: var(--space-sm);
}
.catalog-header-left .section-title {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 4vw, 3.5rem);
  font-weight: 400;
  letter-spacing: -0.01em;
}
.catalog-header-right .section-desc {
  font-size: 0.875rem;
  color: var(--text-secondary);
  max-width: 320px;
  text-align: right;
  line-height: 1.7;
}

.catalog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-bottom: var(--space-xl);
}

.product-card {
  position: relative;
  overflow: hidden;
  border-radius: 4px;
  background: var(--cream);
  cursor: pointer;
}
.product-card .card-image-wrap {
  position: relative;
  aspect-ratio: 3/4;
  overflow: hidden;
}
.product-card .card-image-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}
.product-card:hover .card-image-wrap img { transform: scale(1.04); }
.product-card .card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(26,26,24,0.3) 0%, transparent 50%);
  opacity: 0;
  transition: opacity 0.4s ease;
}
.product-card:hover .card-overlay { opacity: 1; }
.product-card .card-body {
  padding: 1.25rem 1.25rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.product-card .card-body .product-name {
  font-family: var(--font-display);
  font-size: 1.05rem;
  font-weight: 500;
}
.product-card .card-body .product-price {
  font-family: var(--font-body);
  font-size: 0.85rem;
  font-weight: 600;
  color: #333333;
}

.catalog-cta { text-align: center; }
.catalog-cta .btn-outline {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-family: var(--font-body);
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 1rem 2.5rem;
  border: 1px solid var(--charcoal);
  border-radius: 100px;
  background: none;
  cursor: pointer;
  transition: all 0.3s ease;
}
.catalog-cta .btn-outline:hover {
  background: var(--charcoal);
  color: var(--ivory);
}

/* ========== ABOUT SECTION ========== */
.about-section {
  padding: var(--space-3xl) 0;
  background: var(--warm-white);
}
.about-inner {
  max-width: var(--container);
  margin: 0 auto;
  padding: 0 var(--side-pad);
}
.about-top {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-3xl);
  align-items: start;
  margin-bottom: var(--space-3xl);
}
.about-left .section-label {
  font-family: var(--font-body);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: var(--space-md);
}
.about-left .about-title {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 4vw, 3.8rem);
  font-weight: 400;
  line-height: 1.1;
  margin-bottom: var(--space-md);
}
.about-left .about-subtitle {
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-style: italic;
  font-weight: 400;
  color: var(--text-secondary);
  line-height: 1.6;
}
.about-right { padding-top: 1rem; }
.about-right .about-text {
  font-size: 0.9rem;
  line-height: 1.85;
  color: var(--text-secondary);
  margin-bottom: var(--space-lg);
}
.about-right .about-highlight {
  font-family: var(--font-display);
  font-size: 1.3rem;
  font-weight: 400;
  line-height: 1.5;
  color: var(--text-primary);
  padding-left: 1.5rem;
  border-left: 2px solid var(--olive);
}

.about-images {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 1.5rem;
  max-height: 480px;
}
.about-images .about-img {
  border-radius: 4px;
  overflow: hidden;
}
.about-images .about-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.8s ease;
}
.about-images .about-img:hover img { transform: scale(1.03); }

/* ========== HOW WE WORK ========== */
.process-section { padding: var(--space-3xl) 0; }
.process-header {
  text-align: center;
  margin-bottom: var(--space-2xl);
}
.process-header .section-label {
  font-family: var(--font-body);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: var(--space-sm);
}
.process-header .section-title {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 4vw, 3.5rem);
